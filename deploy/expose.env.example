# Copy to /etc/expose.env on your server and fill in your values.
# chmod 600 /etc/expose.env

# Your base domain (tunnels will be served at <subdomain>.<EXPOSE_DOMAIN>)
EXPOSE_DOMAIN=example.com

# GitHub username allowed to create tunnels
EXPOSE_ALLOWED_USER=your-github-username

# DigitalOcean API token (for DNS-01 cert challenge)
DO_AUTH_TOKEN=

# Email for Let's Encrypt registration
EXPOSE_ACME_EMAIL=you@example.com

# TLS cert storage directory
EXPOSE_CERT_DIR=/var/lib/expose/certs

# Set to true to use Let's Encrypt staging (for testing)
# EXPOSE_STAGING=true
